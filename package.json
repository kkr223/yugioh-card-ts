{
  "name": "yugioh-card-ts",
  "version": "2.0.0",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./document": {
      "types": "./dist/src/yugioh-card/document.d.ts",
      "import": "./dist/src/yugioh-card/document.js"
    },
    "./compress-text": {
      "types": "./dist/src/compress-text/index.d.ts",
      "import": "./dist/src/compress-text/index.js"
    },
    "./dist/*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "dev:node": "vite-node --watch src/server.js",
    "play": "vite --open /play/index.html",
    "build": "vite build",
    "build:lib": "vite build --mode lib",
    "preview": "vite preview",
    "test": "node --test",
    "typecheck": "tsc -p tsconfig.json",
    "test:package": "node scripts/package-smoke.mjs",
    "publish": "pnpm publish dist --registry https://registry.npmjs.org",
    "lint": "eslint",
    "lint-fix": "eslint --fix"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kkr223/yugioh-card-ts"
  },
  "keywords": [
    "yugioh-card-ts",
    "yugioh-card",
    "yugioh",
    "rush-duel",
    "ygo",
    "leafer",
    "canvas"
  ],
  "author": "kooriookami",
  "license": "MIT",
  "dependencies": {
    "css-line-break": "^2.1.0"
  },
  "peerDependencies": {
    "@leafer/node": "^2.0.4",
    "leafer": "^2.0.4",
    "leafer-unified": "^1.0.3",
    "skia-canvas": "^2.0.2"
  },
  "peerDependenciesMeta": {
    "@leafer/node": {
      "optional": true
    },
    "skia-canvas": {
      "optional": true
    }
  },
  "devDependencies": {
    "@iconify/vue": "^5.0.0",
    "@leafer/node": "^2.0.4",
    "@element-plus/icons-vue": "^2.3.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "element-plus": "^2.13.6",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "json-editor-vue": "^0.18.1",
    "leafer": "^2.0.4",
    "leafer-unified": "^1.0.3",
    "normalize.css": "^8.0.1",
    "sass-embedded": "^1.98.0",
    "skia-canvas": "^2.0.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.2",
    "vite-node": "^6.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-static-copy": "^4.0.0",
    "vue": "^3.5.30",
    "yugioh-card-v190": "npm:yugioh-card@1.9.2"
  },
  "engines": {
    "node": ">= 22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "skia-canvas"
    ]
  }
}
