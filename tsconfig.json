{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext", "DOM"],
    "allowJs": true,
    "allowImportingTsExtensions": true,
    "checkJs": false,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "rewriteRelativeImportExtensions": true
  },
  "include": [
    "packages/**/*.js",
    "packages/**/*.ts"
  ],
  "exclude": [
    "packages/**/__tests__/**"
  ]
}
